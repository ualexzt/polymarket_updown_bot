# === Bot mode (PAPER only in v1) ===
BOT_MODE=paper

# === Asset / timeframe ===
BTC_SYMBOL=BTCUSDT
DEFAULT_TIMEFRAME=15m

# === Polymarket event (optional - leave blank for auto-discovery) ===
POLYMARKET_EVENT_URL=
POLYMARKET_EVENT_SLUG=

# === Value entry thresholds ===
SAFETY_BUFFER=0.04
MIN_EDGE=0.04
MAX_SPREAD=0.03
MIN_LIQUIDITY_USD=25
MIN_HISTORICAL_PROBABILITY=0.60
MIN_SAMPLES=60

# === Position / risk caps ===
MAX_POSITION_USD=5
MAX_DAILY_LOSS_USD=10
MAX_OPEN_POSITIONS=1

# === Stage gates ===
ALLOW_AFTER_5M=true
ALLOW_AFTER_10M=true

# === Paper bankroll ===
PAPER_STARTING_BALANCE_USD=100

# === Freshness windows (seconds) ===
BINANCE_PRICE_MAX_AGE_SECONDS=10
POLY_ORDERBOOK_MAX_AGE_SECONDS=5
POLY_MARKET_METADATA_MAX_AGE_SECONDS=60

# === Mark intervals (seconds) ===
PAPER_MARK_INTERVAL_SECONDS_5M=10
PAPER_MARK_INTERVAL_SECONDS_15M=15

# === State rules path ===
# Path is relative to project root. Generated from research CSV by scripts/build_state_rules.py.
STATE_RULES_PATH=config/btc_updown_state_rules_15m.json

# === SQLite DB path ===
DATABASE_PATH=data/polymarket_round_paper.sqlite

# === HTTP timeouts ===
HTTP_TIMEOUT_SECONDS=15
HTTP_USER_AGENT=polymarket-round-bot/0.1
